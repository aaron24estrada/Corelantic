# Corelantic web configuration. Copy to .env.local and fill in real values.
# Real secrets never get committed — only this .env.example is tracked (see ../../SECURITY.md).

# Private API origin, called server-to-server by the BFF (never exposed to the browser).
# The generated client paths already include /api/v1, so this is the origin only.
API_BASE_URL=http://127.0.0.1:8080

# Shared secret presented to the private API; must match CORELANTIC_API_INTERNAL_API_KEY.
INTERNAL_API_KEY=

# Auth provider config is added once the identity decision is settled (docs O-4).
