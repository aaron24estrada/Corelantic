# Corelantic API configuration. Copy to .env and fill in real values.
# Real secrets never get committed — only this .env.example is tracked (see ../../SECURITY.md).

# Server
CORELANTIC_API_HOST=127.0.0.1
CORELANTIC_API_PORT=8080

# Shared secret the web BFF presents on every request. Generate with: openssl rand -hex 32
CORELANTIC_API_INTERNAL_API_KEY=

# Provider selection
CORELANTIC_API_DATA_SOURCE=azure_sql
CORELANTIC_API_LLM_PROVIDER=claude

# Read-only connection to the source database. Leave blank until provisioned (docs O-1).
CORELANTIC_API_DATABASE_URL=

# LLM credentials. Leave blank until provisioned.
CORELANTIC_API_ANTHROPIC_API_KEY=
