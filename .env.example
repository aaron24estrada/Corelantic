# Docker Compose configuration. Copy to `.env` beside compose.yaml and fill in.
# Each app keeps its own .env.example for local dev; this one is the deployment.

# Presented by the web BFF to the private API. Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# `fixture` serves seeded, KRW-ballpark data and needs nothing external. `azure_sql` also needs
# the credentials below, plus this host's public IP allow-listed on the Azure SQL server.
CORELANTIC_API_DATA_SOURCE=fixture

CORELANTIC_API_AZURE_SQL_SERVER=krw-platform-sql.database.windows.net
CORELANTIC_API_AZURE_SQL_DATABASE=krw-platform
CORELANTIC_API_ALLOWED_SOURCE_SCHEMAS=gold_tspot

# Read-only service principal on gold_tspot. Blank until provisioned.
CORELANTIC_API_AZURE_SQL_AUTH_MODE=service_principal
CORELANTIC_API_AZURE_SQL_TENANT_ID=
CORELANTIC_API_AZURE_SQL_CLIENT_ID=
CORELANTIC_API_AZURE_SQL_CLIENT_SECRET=
