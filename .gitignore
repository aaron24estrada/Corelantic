# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# Environment — never commit real secrets; only .env.example is tracked
.env
.env.*
!.env.example

# Proxy credentials (password hashes), generated on the host
deploy/htpasswd

# OS / editor
.DS_Store
*.log

# Generated OpenAPI schema (intermediate; the typed client is committed instead)
apps/api/openapi.json

# Local working files (notes, trackers, anything with secrets — not shared)
docs/_local/
